choice = int(input("1.Circle 2.Rectangle 3.Square 4.Triangle: "))

if choice == 1:
    r = float(input())
    print(3.14 * r * r)

elif choice == 2:
    l = float(input())
    b = float(input())
    print(l * b)

elif choice == 3:
    a = float(input())
    print(a * a)

elif choice == 4:
    b = float(input())
    h = float(input())
    print(0.5 * b * h)
