units = int(input())

# Step 1: Calculate bill
if units < 200:
    bill = units * 1.20
elif units < 400:
    bill = units * 1.50
elif units < 600:
    bill = units * 1.80
else:
    bill = units * 2.00

# Step 2: Add surcharge
if bill > 400:
    total = bill + 0.15 * bill
else:
    total = bill + 100

# Step 3: Print result
print(f"{total:.2f}")
