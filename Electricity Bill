# Input number of units consumed
units = int(input())

# Determine cost per unit
if units < 200:
    cost_per_unit = 1.20
elif units < 400:
    cost_per_unit = 1.40
elif units < 600:
    cost_per_unit = 1.60
elif units < 800:
    cost_per_unit = 1.80
else:
    cost_per_unit = 2.00

# Calculate bill
bill = units * cost_per_unit

# Calculate surcharge if bill exceeds 400
surcharge = 0
if bill > 400:
    surcharge = 0.15 * bill

# Total amount
total_amount = bill + surcharge

# Print results with 2 decimal places
print(f"Units Consumed: {units}")
print(f"Cost per Unit: {cost_per_unit:.2f}")
print(f"Bill: {bill:.2f}")
print(f"Surcharge: {surcharge:.2f}")
print(f"Total Amount: {total_amount:.2f}")
