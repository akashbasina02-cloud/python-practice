# Read input value (total amount)
X = int(input())

# Check if it is possible to form X using 5 and 10 rupee coins
# If X is not divisible by 5, it's impossible
if X % 5 != 0:
    print(-1)
else:
    # Take maximum number of 10 rupee coins
    tens = X // 10
    
    # Find the remaining amount after using 10 rupee coins
    remaining = X % 10
    
    # Convert remaining amount into 5 rupee coins
    fives = remaining // 5
    
    # Total minimum coins = 10 rupee coins + 5 rupee coins
    print(tens + fives)
